mainmenu "RP2350 Relay 6CH application"

config RP2350_RELAY_6CH_INDICATORS
	bool "Enable local RGB LED and buzzer status indicators"
	default y
	depends on LED_STRIP && PWM
	help
	  Enable controller-level local status indication using the board's
	  WS2812 RGB LED and passive PWM buzzer when those devices are present.

config RP2350_RELAY_6CH_BUZZER_FEEDBACK
	bool "Enable local bounded buzzer notifications"
	depends on RP2350_RELAY_6CH_INDICATORS
	default n
	help
	  Enable bounded audible notifications for boot-ready, rejected commands,
	  owner-lost faults, and reboot-pending transitions. Accepted commands,
	  normal heartbeat, idle-ready state, and routine relay toggles remain
	  silent by default.

config RP2350_RELAY_6CH_BUZZER_ACCEPTED_FEEDBACK
	bool "Enable accepted-command buzzer feedback"
	depends on RP2350_RELAY_6CH_BUZZER_FEEDBACK
	default n
	help
	  Enable one short beep for accepted commands. This is intended for
	  bench/debug configurations; normal lab and server-room builds should
	  leave accepted commands visual-only.

config RP2350_RELAY_6CH_DISPLAY
	bool "Enable optional OLED local status display"
	select DISPLAY if !ZTEST
	default n
	help
	  Enable the optional 128x64 SSD1306-compatible OLED local status
	  display when a zephyr,display device is present. Missing display
	  hardware is treated as an optional add-on absence, not a controller
	  fault.

config RP2350_RELAY_6CH_DISPLAY_ROTATED_180
	bool "Rotate the optional OLED local status display 180 degrees"
	depends on RP2350_RELAY_6CH_DISPLAY
	default n
	help
	  Rotate the optional OLED local status display 180 degrees for
	  installations where the OLED panel is mounted upside down.

config RP2350_RELAY_6CH_DISPLAY_REVERSED_RELAY_CELLS
	bool "Reverse optional OLED relay cell order"
	depends on RP2350_RELAY_6CH_DISPLAY
	default y if BOARD_WAVESHARE_RP2350_RELAY_6CH
	default n
	help
	  Render the optional OLED relay cells from CH6 to CH1 left-to-right.
	  This is useful for boards or enclosures whose physical relay labels
	  run in the opposite direction from the logical channel numbering.

config RP2350_RELAY_6CH_WATCHDOG
	bool "Enable runtime hardware watchdog supervisor"
	depends on WATCHDOG || ZTEST
	default y if WATCHDOG
	default y if ZTEST
	help
	  Enable a central runtime watchdog supervisor that starts after relay
	  GPIO and management RPC readiness, then feeds the hardware watchdog
	  only while fatal health gates remain clear.

config RP2350_RELAY_6CH_WATCHDOG_TIMEOUT_MS
	int "Runtime watchdog timeout in milliseconds"
	default 10000
	range 100 600000
	help
	  Hardware watchdog timeout used by the runtime supervisor.

config RP2350_RELAY_6CH_WATCHDOG_FEED_INTERVAL_MS
	int "Runtime watchdog feed interval in milliseconds"
	default 2000
	range 10 300000
	help
	  Period between supervisor feed checks. Keep this below the hardware
	  watchdog timeout with enough margin for normal firmware latency.

choice RP2350_RELAY_6CH_COMM_LOSS_POLICY
	prompt "Communication-loss relay safety policy"
	default RP2350_RELAY_6CH_COMM_LOSS_ENERGIZED_ONLY
	help
	  Select how firmware applies the communication-loss off-all timeout.

config RP2350_RELAY_6CH_COMM_LOSS_ENERGIZED_ONLY
	bool "Energized-only timeout"
	help
	  Arm or renew the timeout only while a relay is on or pulsing, and disarm
	  it when all relays are off.

config RP2350_RELAY_6CH_COMM_LOSS_NO_TIMEOUT
	bool "No communication-loss timeout"
	help
	  Leave relay state unchanged on host communication loss. Heartbeat remains
	  a liveness command only.

config RP2350_RELAY_6CH_COMM_LOSS_ALWAYS_ON_OWNER
	bool "Always-on owner timeout"
	help
	  Start the timeout at boot, renew it on heartbeat and relay-control
	  commands, and keep it armed even while all relays are off.

endchoice

config RP2350_RELAY_6CH_COMM_LOSS_TIMEOUT_MS
	int "Communication-loss timeout in milliseconds"
	default 5000
	range 1 600000
	help
	  Timeout used by communication-loss policies that force all relays off.
	  The standard product profile uses 5000 ms.

config RP2350_RELAY_6CH_COMM_LOSS_ALWAYS_ON_OWNER_REBOOT_ON_TIMEOUT
	bool "Reboot on always-on owner communication-loss timeout"
	depends on RP2350_RELAY_6CH_COMM_LOSS_ALWAYS_ON_OWNER && REBOOT
	default n
	help
	  After an always-on owner communication-loss timeout, force all relays
	  off, show reboot-pending local indication, and cold reboot the firmware
	  to recover the application and USB communication path.

config RP2350_RELAY_6CH_COMM_LOSS_REBOOT_DELAY_MS
	int "Always-on owner timeout reboot delay in milliseconds"
	default 60000
	range 0 600000
	help
	  Delay between an always-on owner communication-loss timeout all-off
	  safety action and the cold reboot used for unattended recovery.
	  Heartbeat or relay-control commands that restore ownership before this
	  delay expires cancel the pending reboot. This value is reported as 0
	  when reboot-on-timeout is disabled.

source "Kconfig.zephyr"
