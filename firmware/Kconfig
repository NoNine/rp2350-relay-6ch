mainmenu "RP2350 Relay 6CH application"

config RP2350_RELAY_6CH_INDICATORS
	bool "Enable local RGB LED and buzzer status indicators"
	default y
	depends on LED_STRIP && PWM
	help
	  Enable controller-level local status indication using the board's
	  WS2812 RGB LED and passive PWM buzzer when those devices are present.

config RP2350_RELAY_6CH_BUZZER_FEEDBACK
	bool "Enable local buzzer command feedback"
	depends on RP2350_RELAY_6CH_INDICATORS
	default n
	help
	  Enable bounded audible command feedback. The development firmware
	  enables this in prj.conf so hardware smoke tests can verify the
	  buzzer path; release or quiet-site builds can disable it explicitly.

config RP2350_RELAY_6CH_DISPLAY
	bool "Enable optional OLED local status display"
	select DISPLAY if !ZTEST
	default n
	help
	  Enable the optional 128x64 SSD1306-compatible OLED local status
	  display when a zephyr,display device is present. Missing display
	  hardware is treated as an optional add-on absence, not a controller
	  fault.

config RP2350_RELAY_6CH_DISPLAY_ROTATED_180
	bool "Rotate the optional OLED local status display 180 degrees"
	depends on RP2350_RELAY_6CH_DISPLAY
	default n
	help
	  Rotate the optional OLED local status display 180 degrees for
	  installations where the OLED panel is mounted upside down.

source "Kconfig.zephyr"
