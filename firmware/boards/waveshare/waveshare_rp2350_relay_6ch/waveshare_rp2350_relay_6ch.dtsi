/*
 * SPDX-License-Identifier: Apache-2.0
 *
 * This board definition follows Zephyr's Raspberry Pi Pico 2 W board as the
 * base reference, then changes the SoC include to RP2350B and maps the
 * Waveshare RP2350-Relay-6CH pin assignments.
 */

#include <freq.h>

#include <zephyr/dt-bindings/i2c/i2c.h>
#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <zephyr/dt-bindings/led/led.h>
#include <zephyr/dt-bindings/pwm/pwm.h>

#include "waveshare_rp2350_relay_6ch-pinctrl.dtsi"

/ {
	chosen {
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,flash-controller = &qmi;
		zephyr,console = &uart0;
		zephyr,shell-uart = &uart0;
		zephyr,display = &ssd1306;
	};

	aliases {
		watchdog0 = &wdt0;
		led-strip = &rgb_led;
	};

	zephyr,user {
		pwms = <&pwm 7 PWM_USEC(1000) PWM_POLARITY_NORMAL>;
	};

	relays {
		compatible = "gpio-leds";

		ch1 {
			gpios = <&gpio0 26 GPIO_ACTIVE_HIGH>;
		};

		ch2 {
			gpios = <&gpio0 27 GPIO_ACTIVE_HIGH>;
		};

		ch3 {
			gpios = <&gpio0 28 GPIO_ACTIVE_HIGH>;
		};

		ch4 {
			gpios = <&gpio0 29 GPIO_ACTIVE_HIGH>;
		};

		ch5 {
			gpios = <&gpio0 30 GPIO_ACTIVE_HIGH>;
		};

		ch6 {
			gpios = <&gpio0 31 GPIO_ACTIVE_HIGH>;
		};
	};

	pico_header: connector {
		compatible = "raspberrypi,pico-header";
		#gpio-cells = <2>;
		gpio-map-mask = <0xffffffff 0xffffffc0>;
		gpio-map-pass-thru = <0 0x3f>;
		gpio-map = <0 0 &gpio0 0 0>,	/* GP0 */
			   <1 0 &gpio0 1 0>,	/* GP1 */
			   <2 0 &gpio0 2 0>,	/* GP2 */
			   <3 0 &gpio0 3 0>,	/* GP3 */
			   <4 0 &gpio0 4 0>,	/* GP4 */
			   <5 0 &gpio0 5 0>,	/* GP5 */
			   <6 0 &gpio0 6 0>,	/* GP6 */
			   <7 0 &gpio0 7 0>,	/* GP7 */
			   <8 0 &gpio0 8 0>,	/* GP8 */
			   <9 0 &gpio0 9 0>,	/* GP9 */
			   <10 0 &gpio0 10 0>,	/* GP10 */
			   <11 0 &gpio0 11 0>,	/* GP11 */
			   <12 0 &gpio0 12 0>,	/* GP12 */
			   <13 0 &gpio0 13 0>,	/* GP13 */
			   <14 0 &gpio0 14 0>,	/* GP14 */
			   <15 0 &gpio0 15 0>,	/* GP15 */
			   <16 0 &gpio0 16 0>,	/* GP16 */
			   <17 0 &gpio0 17 0>,	/* GP17 */
			   <18 0 &gpio0 18 0>,	/* GP18 */
			   <19 0 &gpio0 19 0>,	/* GP19 */
			   <20 0 &gpio0 20 0>,	/* GP20 */
			   <21 0 &gpio0 21 0>,	/* GP21 */
			   <22 0 &gpio0 22 0>,	/* GP22 */
			   <26 0 &gpio0_hi 8 0>,	/* GP40 / ADC0 */
			   <27 0 &gpio0_hi 9 0>,	/* GP41 / ADC1 */
			   <28 0 &gpio0_hi 10 0>;	/* GP42 / ADC2 */
	};
};

&flash0 {
	reg = <0x10000000 DT_SIZE_M(16)>;
};

&uart0 {
	current-speed = <115200>;
	pinctrl-0 = <&uart0_default>;
	pinctrl-names = "default";
	status = "okay";
};

&uart1 {
	current-speed = <115200>;
	pinctrl-0 = <&uart1_default>;
	pinctrl-names = "default";
	status = "disabled";
};

gpio0_lo: &gpio0 {
	status = "okay";
};

/*
 * gpio1 is a board-local label for RP2350B's high GPIO bank. For gpio0_hi,
 * offset N maps to physical GPIO number GP(32 + N).
 */
gpio1: &gpio0_hi {
	status = "okay";
};

&spi0 {
	clock-frequency = <DT_FREQ_M(8)>;
	pinctrl-0 = <&spi0_default>;
	pinctrl-names = "default";
};

&i2c0 {
	clock-frequency = <I2C_BITRATE_STANDARD>;
	pinctrl-0 = <&i2c0_default>;
	pinctrl-names = "default";
	status = "okay";
};

&i2c1 {
	clock-frequency = <I2C_BITRATE_STANDARD>;
	pinctrl-0 = <&i2c1_default>;
	pinctrl-names = "default";
	status = "okay";

	ssd1306: ssd1306@3d {
		compatible = "solomon,ssd1306";
		reg = <0x3d>;
		width = <128>;
		height = <64>;
		segment-offset = <0>;
		page-offset = <0>;
		display-offset = <0>;
		multiplex-ratio = <63>;
		segment-remap;
		com-invdir;
		prechargep = <0x22>;
		softreset-on;
	};
};

&adc {
	pinctrl-0 = <&adc_default>;
	pinctrl-names = "default";
	status = "okay";
};

&pwm {
	pinctrl-0 = <&pwm_buzzer_default>;
	pinctrl-names = "default";
	status = "okay";
};

&pio1 {
	status = "okay";

	pio1_ws2812 {
		compatible = "rp2350-relay-6ch,waveshare-ws2812-pio";
		pinctrl-0 = <&ws2812_pio1_default>;
		pinctrl-names = "default";
		bit-waveform = <3>, <3>, <4>;
		status = "okay";

		rgb_led: rgb_led {
			/* RGB_CTRL: GP36, gpio0_hi offset 4. */
			gpios = <&gpio0_hi 4 GPIO_ACTIVE_HIGH>;
			chain-length = <1>;
			color-mapping = <LED_COLOR_ID_RED LED_COLOR_ID_GREEN LED_COLOR_ID_BLUE>;
			reset-delay = <280>;
			frequency = <DT_FREQ_K(800)>;
			status = "okay";
		};
	};
};

&timer0 {
	status = "okay";
};

&wdt0 {
	status = "okay";
};

&rng {
	status = "okay";
};

zephyr_udc0: &usbd {
	status = "okay";
};

pico_spi: &spi0 {};

pico_spi0: &spi0 {};

pico_i2c: &i2c0 {};

pico_i2c0: &i2c0 {};

pico_i2c1: &i2c1 {};

pico_serial: &uart0 {};

pico_serial0: &uart0 {};
